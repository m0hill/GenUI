{
  "name": "@hono-ai/example-chat",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n css,server \"pnpm run css:watch\" \"nub watch src/index.tsx\"",
    "test": "nub --test $(find src -name '*.test.ts' -print)",
    "build": "pnpm run css:build",
    "start": "nub src/index.tsx",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run build",
    "typecheck": "tsc --noEmit",
    "css:build": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "css:watch": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "lint": "oxlint src --type-aware",
    "lint:fix": "oxlint src --type-aware --fix",
    "format": "oxfmt src package.json tsconfig.json",
    "format:check": "oxfmt --check src package.json tsconfig.json"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.0",
    "@hono/node-server": "^1.19.6",
    "datastar-kit": "^0.4.0",
    "hono": "^4.12.19",
    "marked": "^15.0.12",
    "zod": "^4.4.3"
  }
}
