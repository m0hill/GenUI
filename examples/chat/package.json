{
  "name": "chat",
  "type": "module",
  "scripts": {
    "check": "nub run lint && nub run format:check && nub run typecheck && nub run test",
    "dev": "nub watch src/index.tsx",
    "build": "tsc",
    "format": "oxfmt src public package.json tsconfig.json",
    "format:check": "oxfmt --check src public package.json tsconfig.json",
    "lint": "oxlint src --type-aware",
    "start": "node dist/index.js",
    "test": "nub --test $(find src -name '*.test.ts' -print)",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@hono/node-server": "^2.0.8",
    "datastar-kit": "^0.4.0",
    "genui": "workspace:*",
    "hono": "^4.12.28",
    "micromark": "^4.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.8.3"
  }
}
