{
  "name": "@genui/playground",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-client.mjs",
    "check": "nub run lint && nub run format:check && nub run typecheck && nub run test",
    "dev": "nub run build && nub watch src/server.ts",
    "eval": "nub run build && nub src/eval.ts",
    "format": "oxfmt src scripts *.json",
    "format:check": "oxfmt --check src scripts *.json",
    "lint": "oxlint src --type-aware",
    "lint:fix": "oxlint src --type-aware --fix",
    "start": "nub run build && nub src/server.ts",
    "test": "nub run build && nub --test $(find src -name '*.test.ts' -print)",
    "test:reliability": "nub run build && nub --test src/reliability.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "genui": "workspace:*",
    "hono": "^4.12.28",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@genui/check": "workspace:*",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1"
  }
}
