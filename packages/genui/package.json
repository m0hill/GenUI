{
  "name": "genui",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "import": "./dist/dom/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "browser:install": "playwright install chromium",
    "test": "nub --test $(find src -name '*.test.ts' -print)",
    "check": "nub run lint && nub run format:check && nub run typecheck && nub run test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --type-aware",
    "lint:fix": "oxlint src --type-aware --fix",
    "format": "oxfmt src *.json",
    "format:check": "oxfmt --check src *.json"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1"
  }
}
