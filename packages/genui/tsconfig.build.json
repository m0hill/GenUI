{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/check/index.ts",
    "src/dom/index.ts",
    "src/protocol/index.ts",
    "src/testing/index.ts"
  ],
  "exclude": ["node_modules"]
}
