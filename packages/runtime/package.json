{
  "name": "@hono-ai/genui-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dom": "./src/dom/index.ts"
  },
  "scripts": {
    "browser:install": "playwright install chromium",
    "sandbox:build": "node ./scripts/build-sandbox-asset.mjs",
    "test": "pnpm run sandbox:build && nub --test $(find src -name '*.test.ts' -print)",
    "check": "pnpm run sandbox:build && pnpm run lint && pnpm run format:check && tsc --noEmit && nub --test $(find src -name '*.test.ts' -print)",
    "typecheck": "pnpm run sandbox:build && tsc --noEmit",
    "lint": "oxlint src --type-aware",
    "lint:fix": "oxlint src --type-aware --fix",
    "format": "oxfmt src scripts package.json tsconfig.json",
    "format:check": "oxfmt --check src scripts package.json tsconfig.json"
  },
  "dependencies": {
    "parse5": "^8.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1"
  }
}
