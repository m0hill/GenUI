{
  "name": "@genui/genui",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dom": {
      "types": "./dist/dom/index.d.ts",
      "import": "./dist/dom/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "browser:install": "playwright install chromium",
    "test": "nub --test $(find src -name '*.test.ts' -print)",
    "check": "pnpm run lint && pnpm run format:check && tsc --noEmit && nub --test $(find src -name '*.test.ts' -print)",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --type-aware",
    "lint:fix": "oxlint src --type-aware --fix",
    "format": "oxfmt src package.json tsconfig.json",
    "format:check": "oxfmt --check src package.json tsconfig.json"
  },
  "dependencies": {
    "@genui/protocol": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1"
  }
}
