{
  "name": "hono-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n css,server \"nub run css:watch\" \"nub watch src/index.tsx\"",
    "test": "nub --test $(find src -name '*.test.ts' -print)",
    "build": "nub run css:build",
    "start": "nub src/index.tsx",
    "check": "nub run lint && nub run format:check && nub run typecheck && nub run build",
    "typecheck": "tsc --noEmit",
    "css:build": "tailwindcss -i ./src/styles.css -o ./public/styles.css --minify",
    "css:watch": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "lint": "oxlint src --type-aware",
    "lint:fix": "oxlint src --type-aware --fix",
    "format": "oxfmt src package.json tsconfig.json .oxlintrc.json",
    "format:check": "oxfmt --check src package.json tsconfig.json .oxlintrc.json"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.0",
    "@hono/node-server": "^1.19.6",
    "datastar-kit": "^0.4.0",
    "hono": "^4.12.19",
    "marked": "^15.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "^4.0.0",
    "typescript": "7.0.1-rc"
  }
}
